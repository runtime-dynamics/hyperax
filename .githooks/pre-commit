#!/bin/zsh
set -e

echo "=== Pre-commit: Go build ==="
if ! go build ./... 2>&1; then
  echo "FAILED: Go build errors. Fix before committing."
  exit 1
fi

echo "=== Pre-commit: TypeScript check ==="
if ! (cd ui && npx tsc --noEmit) 2>&1; then
  echo "FAILED: TypeScript errors. Fix before committing."
  exit 1
fi

echo "=== Pre-commit: Go vet ==="
if ! go vet ./... 2>&1; then
  echo "FAILED: go vet found issues. Fix before committing."
  exit 1
fi

echo "=== Pre-commit checks passed ==="
